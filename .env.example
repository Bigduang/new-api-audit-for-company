AUDIT_DATABASE_URL=sqlite:////opt/token-audit/data/token_audit.db
AUDIT_SECRET=replace-with-shared-hmac-secret
AUDIT_PROMPT_ENCRYPTION_KEY=base64:replace-with-base64-16-24-or-32-byte-key
AUDIT_TIMEZONE=Asia/Shanghai
AUDIT_RETENTION_DAYS=30
AUDIT_MAX_BODY_BYTES=2097152
AUDIT_PUBLIC_BASE_URL=https://ai-audit.example.com
AUDIT_REPORT_ACCESS_TOKEN=replace-with-long-random-report-token

# Optional LLM classifier, OpenAI-compatible. Current production target: DeepSeek.
AUDIT_LLM_ENABLED=false
AUDIT_LLM_BASE_URL=https://api.deepseek.com
AUDIT_LLM_API_KEY=sk-your-deepseek-api-key
AUDIT_LLM_MODEL=deepseek-v4-flash
AUDIT_LLM_TIMEOUT_SECONDS=20
AUDIT_LLM_MIN_CONFIDENCE=0.75

# Optional WeCom report push.
WX_CORPID=
WX_APPSECRET=
WX_AGENT_ID=0

# New-API side variables after applying patches/new-api-audit-hook.patch:
# AUDIT_ENABLED=false
# AUDIT_ENDPOINT=http://token-audit:8000
# AUDIT_SECRET=replace-with-shared-hmac-secret
# AUDIT_TIMEOUT_MS=800
# AUDIT_QUEUE_SIZE=1000
# AUDIT_MAX_EVENT_BYTES=1048576
# AUDIT_EXCLUDED_TOKEN_NAMES=audit-classifier
